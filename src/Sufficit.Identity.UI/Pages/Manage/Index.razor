@page "/manage"
@attribute [Authorize]
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Minha conta — Sufficit Identity</PageTitle>

<div class="auth-card manage-grid">
    <h1>Minha conta</h1>

    <div class="profile-card">
        <div class="profile-avatar">@(_user?.UserName?.Substring(0,1).ToUpper())</div>
        <div>
            <h2>@_user?.UserName</h2>
            <p class="muted">@_user?.Email</p>
            @if (_emailConfirmed)
            {
                <span class="badge badge-success">E-mail confirmado</span>
            }
            else
            {
                <span class="badge badge-warning">E-mail não confirmado</span>
            }
        </div>
    </div>

    <nav class="manage-nav">
        <a href="/manage/changepassword" class="manage-link">Alterar senha</a>
        <a href="/manage/twofactor" class="manage-link">Autenticação em 2 etapas</a>
        <a href="/manage/passkeys" class="manage-link">Passkeys (WebAuthn)</a>
        <a href="/manage/externallogins" class="manage-link">Logins externos</a>
        <a href="/manage/grants" class="manage-link">Aplicações conectadas</a>
        <a href="/manage/sessions" class="manage-link">Sessões ativas</a>
        <a href="/manage/personaldata" class="manage-link">Meus dados (LGPD)</a>
    </nav>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? _authTask { get; set; }
    private ApplicationUser? _user;
    private bool _emailConfirmed;

    protected override async Task OnInitializedAsync()
    {
        _user = await _authTask.GetAuthenticatedUserAsync(UserManager);
        if (_user is not null)
            _emailConfirmed = await UserManager.IsEmailConfirmedAsync(_user);
    }
}
