@page "/account/forgotpassword"
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender
@inject CallbackUrlBuilder CallbackUrls
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpAccessor
@inject NavigationManager Navigation
@inject ILogger<ForgotPassword> Logger
@using System.Web

<PageTitle>Esqueceu a senha — Sufficit Identity</PageTitle>

<div class="auth-card">
    <h1>Esqueceu a senha?</h1>

    @if (_emailSent)
    {
        <div class="alert alert-success" role="alert">
            Se o e-mail existir, você receberá instruções para redefinir a senha.
        </div>
        <a href="/account/login" class="btn btn-primary">Voltar ao login</a>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="alert alert-error">@_error</div>
        }
        <EditForm Model="_email" Method="post" OnValidSubmit="SendResetLinkAsync" FormName="forgot">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">E-mail</label>
                <InputText id="email" @bind-Value="_email.Address" class="form-control"
                           autocomplete="email" autofocus />
                <ValidationMessage For="@(() => _email.Address)" />
            </div>

            <button type="submit" class="btn btn-primary btn-block">Enviar link de redefinição</button>
        </EditForm>
    }
</div>

@code {
    private EmailInput? _boundEmail;
    [SupplyParameterFromForm(FormName = "forgot")]
    private EmailInput _email
    {
        get => _boundEmail ??= new();
        set => _boundEmail = value;
    }

    private bool _emailSent;
    private string? _error;

    private async Task SendResetLinkAsync()
    {
        // Always show the same success screen so we don't leak whether the
        // email exists (matches legacy behavior + Identity default).
        var user = await UserManager.FindByEmailAsync(_email.Address);
        if (user is null || !await UserManager.IsEmailConfirmedAsync(user))
        {
            _emailSent = true;
            return;
        }

        try
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var encodedToken = CallbackUrlBuilder.EncodeToken(token);

            var ctx = HttpAccessor.HttpContext;
            var callbackUrl = CallbackUrls.BuildAbsolute(
                ctx ?? throw new InvalidOperationException("HttpContext unavailable"),
                "/account/resetpassword",
                new Dictionary<string, string?>
                {
                    ["userId"] = user.Id,
                    ["code"] = encodedToken
                });

            // Template HTML — compatible with the legacy RabbitMQEmailQueue,
            // which extracts the first <a href="..."> to build the action link.
            var body = $"Redefina sua senha <a href=\"{HttpUtility.HtmlAttributeEncode(callbackUrl)}\">clicando aqui</a>.";

            await EmailSender.SendEmailAsync(
                _email.Address,
                "Redefinir senha — Sufficit Identity",
                body);

            Logger.LogInformation("Password reset email sent to {Email}", _email.Address);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send password reset email to {Email}", _email.Address);
            _error = "Não foi possível enviar o e-mail. Tente novamente mais tarde.";
            return;
        }

        _emailSent = true;
    }

    private sealed class EmailInput
    {
        [Required, EmailAddress]
        public string Address { get; set; } = string.Empty;
    }
}
