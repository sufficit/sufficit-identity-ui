@page "/account/resendemailconfirmation"
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Identity.UI.Services.IEmailSender EmailSender
@inject CallbackUrlBuilder CallbackUrls
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpAccessor
@inject NavigationManager Navigation
@inject ILogger<ResendEmailConfirmation> Logger
@using System.Web

<PageTitle>Reenviar confirmação — Sufficit Identity</PageTitle>

<div class="auth-card">
    <h1>Reenviar confirmação de e-mail</h1>

    @if (_sent)
    {
        <div class="alert alert-success" role="alert">
            Se o e-mail existir, um novo link de confirmação foi enviado.
        </div>
        <a href="/account/login" class="btn btn-primary">Voltar ao login</a>
    }
    else
    {
        @if (_error is not null)
        {
            <div class="alert alert-error">@_error</div>
        }
        <EditForm Model="_model" Method="post" OnValidSubmit="ResendAsync" FormName="resend-confirm">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">E-mail</label>
                <InputText id="email" @bind-Value="_model.Email" class="form-control"
                           autocomplete="email" autofocus />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <button type="submit" class="btn btn-primary btn-block">Reenviar</button>
        </EditForm>
    }
</div>

@code {
    private EmailInput? _boundModel;
    [SupplyParameterFromForm(FormName = "resend-confirm")]
    private EmailInput _model
    {
        get => _boundModel ??= new();
        set => _boundModel = value;
    }
    private bool _sent;
    private string? _error;

    private async Task ResendAsync()
    {
        var user = await UserManager.FindByEmailAsync(_model.Email);
        if (user is null)
        {
            // Don't leak existence
            _sent = true;
            return;
        }

        try
        {
            var token = await UserManager.GenerateEmailConfirmationTokenAsync(user);
            var encodedToken = CallbackUrlBuilder.EncodeToken(token);

            var ctx = HttpAccessor.HttpContext;
            var callbackUrl = CallbackUrls.BuildAbsolute(
                ctx ?? throw new InvalidOperationException("HttpContext unavailable"),
                "/account/confirmemail",
                new Dictionary<string, string?>
                {
                    ["userId"] = user.Id,
                    ["code"] = encodedToken
                });

            var body = $"Confirme sua conta <a href=\"{HttpUtility.HtmlAttributeEncode(callbackUrl)}\">clicando aqui</a>.";
            await EmailSender.SendEmailAsync(_model.Email, "Confirme seu e-mail — Sufficit Identity", body);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to resend confirmation email to {Email}", _model.Email);
            _error = "Não foi possível enviar o e-mail. Tente novamente.";
            return;
        }

        _sent = true;
    }

    private sealed class EmailInput
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
