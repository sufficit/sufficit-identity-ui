@page "/account/resetpassword"
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation
@inject ILogger<ResetPassword> Logger

<PageTitle>Redefinir senha — Sufficit Identity</PageTitle>

<div class="auth-card">
    <h1>Redefinir senha</h1>

    @if (_invalidRequest)
    {
        <div class="alert alert-error">Link de redefinição inválido ou expirado.</div>
        <a href="/account/forgotpassword" class="btn btn-secondary">Solicitar novo link</a>
    }
    else if (_done)
    {
        <div class="alert alert-success">Senha redefinida com sucesso.</div>
        <a href="/account/login" class="btn btn-primary">Entrar</a>
    }
    else
    {
        @if (_error is not null) { <div class="alert alert-error">@_error</div> }

        <EditForm Model="_model" Method="post" OnValidSubmit="ResetAsync" FormName="reset">
            <DataAnnotationsValidator />

            @* Email is read-only context: the user arrived here from a signed
               link containing their UserId. We show their email as plain text
               and forward it as a hidden field on submit so _model.Email is
               populated on POST via [SupplyParameterFromForm]. *@
            <div class="form-group">
                <label>Conta</label>
                <p class="form-control-static"><strong>@_resolvedEmail</strong></p>
                <input type="hidden" name="_model.Email" value="@_resolvedEmail" />
            </div>

            <div class="form-group">
                <label for="password">Nova senha</label>
                <InputText id="password" type="password" @bind-Value="_model.Password" class="form-control"
                           autocomplete="new-password" autofocus />
                <ValidationMessage For="@(() => _model.Password)" />
            </div>
            <div class="form-group">
                <label for="confirm">Confirmar senha</label>
                <InputText id="confirm" type="password" @bind-Value="_model.ConfirmPassword" class="form-control"
                           autocomplete="new-password" />
                <ValidationMessage For="@(() => _model.ConfirmPassword)" />
            </div>

            <button type="submit" class="btn btn-primary btn-block">Redefinir</button>
        </EditForm>
    }
</div>

@code {
    [SupplyParameterFromQuery] private string? UserId { get; set; }
    [SupplyParameterFromQuery(Name = "code")] private string? Token { get; set; }

    private ResetInput? _boundModel;
    [SupplyParameterFromForm(FormName = "reset")]
    private ResetInput _model
    {
        get => _boundModel ??= new();
        set => _boundModel = value;
    }

    private bool _done;
    private bool _invalidRequest;
    private string? _error;
    private string? _resolvedEmail;

    protected override async Task OnInitializedAsync()
    {
        // Reject early if the link is missing the userId/code parameters
        // (matches the legacy AccountController behavior which returns Error).
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            _invalidRequest = true;
            return;
        }

        _model.EncodedToken = Token!;

        // Resolve the user's email from their UserId so we can show it as
        // read-only context (no need for them to retype it). The link already
        // identified them uniquely.
        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            _invalidRequest = true;
            return;
        }

        var resolvedEmail = await UserManager.GetEmailAsync(user) ?? user.UserName;
        if (string.IsNullOrWhiteSpace(resolvedEmail))
        {
            // Should not normally happen (Identity requires a UserName), but
            // guards the non-nullable _model.Email assignment below instead of
            // assigning a possibly-null value to it.
            _invalidRequest = true;
            return;
        }

        _resolvedEmail = resolvedEmail;
        _model.Email = resolvedEmail;
    }

    private async Task ResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.EncodedToken))
        {
            _invalidRequest = true;
            return;
        }

        var user = await UserManager.FindByEmailAsync(_model.Email);
        if (user is null)
        {
            // Don't leak whether the email exists — show generic success
            // matches Identity default behavior.
            _done = true;
            return;
        }

        // Decode Base64Url token (forgot-password page encoded it before sending).
        var token = CallbackUrlBuilder.DecodeToken(_model.EncodedToken);
        var result = await UserManager.ResetPasswordAsync(user, token, _model.Password);

        if (result.Succeeded)
        {
            Logger.LogInformation("Password reset succeeded for {Email}", _model.Email);
            _done = true;
        }
        else
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    private sealed class ResetInput
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;

        [Required]
        [StringLength(100, ErrorMessage = "A senha deve ter pelo menos {2} caracteres.", MinimumLength = 6)]
        [DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string Password { get; set; } = string.Empty;

        [Required]
        [DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        [Compare(nameof(Password), ErrorMessage = "As senhas não conferem.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        // Hidden — populated from query string in OnInitialized.
        public string EncodedToken { get; set; } = string.Empty;
    }
}
